# ============================================
# DATABASE
# ============================================
# Untuk development di laptop (cukup ini saja, jangan isi TURSO_* di bawah):
DATABASE_PATH=./sqlite.db

# Untuk production / supaya bisa diakses dari HP: isi dua baris ini
# dengan data dari akun Turso kamu (gratis, lihat panduan di README).
# TURSO_DATABASE_URL=libsql://nama-db-kamu.turso.io
# TURSO_AUTH_TOKEN=isi-token-dari-turso

# ============================================
# AUTH (WAJIB DIISI)
# ============================================
# Generate string acak: openssl rand -base64 32
BETTER_AUTH_SECRET=ganti-dengan-string-acak-panjang-dan-rahasia
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# AI - SCAN STRUK/KWITANSI (isi salah satu sesuai pilihan di bawah)
# ============================================
# Pilih provider: "openai" atau "gemini"
AI_PROVIDER=openai

# Isi kalau AI_PROVIDER=openai. Dapatkan di https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Isi kalau AI_PROVIDER=gemini. Dapatkan di https://aistudio.google.com/apikey
GEMINI_API_KEY=
